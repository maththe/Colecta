VITE_API_URL=http://localhost:3333

# --- Mapa (Fase 1 — Recinto/Site) ---
# Base "suave" self-host (Protomaps). Sem esta URL, o mapa usa OSM padrão (dev).
# Em produção, aponte para o .pmtiles servido por range requests (bucket/volume).
# Ver docs/tiles-pmtiles.md.
# VITE_PMTILES_URL=https://tiles.exemplo.com/recinto.pmtiles
# Flavor de estilo do Protomaps (padrão: light).
# VITE_PMTILES_FLAVOR=light
# Chave do MapTiler para a base de satélite (baseMode=satellite). Sem ela, OSM.
# VITE_MAPTILER_KEY=sua_chave_maptiler
