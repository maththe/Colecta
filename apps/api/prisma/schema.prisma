generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TrashBinStatus {
  active
  inactive
  full
  maintenance
  offline
}

enum CameraStatus {
  online
  offline
  maintenance
}

enum TaskStatus {
  pending
  in_progress
  done
  cancelled
}

enum TaskPriority {
  low
  medium
  high
  urgent
}

enum TaskKind {
  manual
  auto
}

enum UserRole {
  ADMIN
  MANUTENCAO
  LIMPEZA
  FINANCEIRO
  SEGURANCA
  /// Legado: mantido para bancos antigos que ainda tenham usuários genéricos.
  FUNCIONARIO
}

enum NotificationKind {
  task_assigned
  task_urgent
  task_overdue
  task_done
  task_auto
}

// Modo de base do mapa do recinto. A arquitetura é estável; a fonte por trás de
// cada modo é configurada no front (Protomaps self-host p/ osm_muted, MapTiler p/
// satellite, ImageOverlay p/ overlay).
enum SiteBaseMode {
  osm_muted
  satellite
  overlay
}

// Recinto: container espacial de topo (parque, zoológico, parque de diversões,
// campo). Toda Location/lixeira/câmera/tarefa pertence a um Site. O `boundary`
// (GeoJSON, sem PostGIS) recorta o mapa e define os limites de navegação.
model Site {
  id          String       @id @default(uuid()) @db.Uuid
  tenantUuid  String
  name        String
  boundary    Json? // GeoJSON Polygon/MultiPolygon do contorno; null = sem recorte
  baseMode    SiteBaseMode @default(osm_muted)
  centerLat   Float?
  centerLng   Float?
  defaultZoom Int?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  locations Location[]
  trashBins TrashBin[]
  cameras   Camera[]
  tasks     Task[]
  zones     Zone[]

  @@index([tenantUuid])
  @@map("sites")
}

// Zona temática dentro de um recinto (Site): subdivide a área em regiões com
// cor/categoria para exibição, métricas e roteamento. O belonging é simétrico ao
// do Site — `TrashBin.zoneId` é a fonte da verdade (persistido), recalculado via
// Turf quando a lixeira move ou a zona muda. Apagar a zona é Cascade a partir do
// Site, mas SetNull nas lixeiras (a lixeira sobrevive, só perde a zona).
model Zone {
  id         String   @id @default(uuid()) @db.Uuid
  tenantUuid String
  siteId     String   @db.Uuid
  site       Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name       String
  category   String?
  color      String?
  polygon    Json // GeoJSON Polygon da zona
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  trashBins TrashBin[]

  @@index([tenantUuid])
  @@index([siteId])
  @@map("zones")
}

model User {
  id         String   @id @default(uuid())
  name       String
  email      String   @unique
  password   String
  tenantUuid String   @default(uuid())
  role       UserRole @default(LIMPEZA)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  startedTasks  Task[]         @relation("TaskStartedBy")
  notifications Notification[]

  @@map("users")
}

model TrashBin {
  id             String         @id @default(uuid()) @db.Uuid
  tenantUuid     String
  name           String
  code           String
  locationId     String?        @db.Uuid
  location       Location?      @relation(fields: [locationId], references: [id], onDelete: Restrict)
  // Recinto ao qual a lixeira pertence (obrigatório). Indoor (com locationId)
  // herda location.siteId; outdoor resolve pela coordenada (ver geo.util).
  siteId         String         @db.Uuid
  site           Site           @relation(fields: [siteId], references: [id], onDelete: Restrict)
  // Zona temática (opcional): persistida e recalculada via Turf quando a lixeira
  // move ou a zona muda. NULL = fora de qualquer zona. SetNull ao apagar a zona.
  zoneId         String?        @db.Uuid
  zone           Zone?          @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  // Coordenadas próprias quando a lixeira está "ao ar livre" (sem construção).
  // Preenchidas juntas ou ambas nulas; nesse caso `locationId` é nulo.
  latitude       Float?
  longitude      Float?
  capacityLiters Int
  status         TrashBinStatus @default(active)
  fillLevel      Int?
  batteryLevel   Int?
  mqttTopic      String?
  distanceEmptyCm Float?
  distanceFullCm  Float?
  // Posicionamento dentro de uma construção (prédio com andares).
  floor          String?  // andar onde a lixeira está, ex: "Térreo", "2", "-1"
  posX           Float?   // posição horizontal na planta do andar (0-100, %)
  posY           Float?   // posição vertical na planta do andar (0-100, %)
  lastSeenAt     DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  sensorReadings SensorReading[]
  tasks          Task[]
  cameras        Camera[]

  @@unique([tenantUuid, code])
  // Roteamento MQTT por device: cada tópico é único dentro do tenant. No Postgres,
  // UNIQUE trata NULLs como distintos, então lixeiras sem device (mqttTopic NULL)
  // não colidem entre si.
  @@unique([tenantUuid, mqttTopic])
  @@index([tenantUuid])
  @@index([locationId])
  @@index([siteId])
  @@index([zoneId])
  @@index([status])
  @@map("trash_bins")
}

model Location {
  id          String   @id @default(uuid()) @db.Uuid
  tenantUuid  String
  name        String
  description String?
  latitude    Float
  longitude   Float
  // Recinto ao qual a construção pertence (obrigatório).
  siteId      String   @db.Uuid
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Restrict)
  // Toda localização é uma construção (prédio): as lixeiras se distribuem por
  // andares e ganham posição interna na planta de cada andar.
  floorsCount Int?
  // Mapa "andar -> imagem da planta (data URL)" para o mapa da construção.
  floorPlans  Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  trashBins TrashBin[]
  tasks     Task[]
  cameras   Camera[]

  @@index([tenantUuid])
  @@index([tenantUuid, name])
  @@index([siteId])
  @@map("locations")
}

model Camera {
  id          String       @id @default(uuid()) @db.Uuid
  tenantUuid  String
  code        String
  name        String
  status      CameraStatus @default(online)
  model       String
  ipAddress   String
  resolution  String
  fps         Int
  latitude    Float
  longitude   Float
  // Recinto ao qual a câmera pertence (obrigatório). Indoor herda location.siteId.
  siteId      String       @db.Uuid
  site        Site         @relation(fields: [siteId], references: [id], onDelete: Restrict)
  // Posicionamento dentro de uma construção (prédio com andares), espelhando TrashBin.
  floor       String?  // andar onde a câmera está, ex: "Térreo", "2", "-1"
  posX        Float?   // posição horizontal na planta do andar (0-100, %)
  posY        Float?   // posição vertical na planta do andar (0-100, %)
  imageUrl    String?
  notes       String?
  lastSeenAt  DateTime?
  locationId  String?      @db.Uuid
  location    Location?    @relation(fields: [locationId], references: [id], onDelete: SetNull)
  trashBinId  String?      @db.Uuid
  trashBin    TrashBin?    @relation(fields: [trashBinId], references: [id], onDelete: SetNull)
  tasks       Task[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([tenantUuid, code])
  @@index([tenantUuid])
  @@index([locationId])
  @@index([trashBinId])
  @@index([siteId])
  @@index([status])
  @@map("cameras")
}

model SensorReading {
  id           String   @id @default(uuid()) @db.Uuid
  tenantUuid   String
  trashBinId   String   @db.Uuid
  trashBin     TrashBin @relation(fields: [trashBinId], references: [id], onDelete: Cascade)
  fillLevel    Int?
  distanceCm   Float?
  batteryLevel Int?
  temperature  Float?
  latitude     Float?
  longitude    Float?
  sensorError  String?
  mqttTopic    String?
  deviceMillis Float?
  payload      Json?
  receivedAt   DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([tenantUuid, receivedAt])
  @@index([tenantUuid, mqttTopic, receivedAt])
  @@index([trashBinId, receivedAt])
  @@map("sensor_readings")
}

model Task {
  id           String       @id @default(uuid()) @db.Uuid
  tenantUuid   String
  title        String
  description  String?
  status       TaskStatus   @default(pending)
  priority     TaskPriority @default(medium)
  kind         TaskKind     @default(manual)
  issues       String[]     @default([])
  trashBinId   String?      @db.Uuid
  trashBin     TrashBin?    @relation(fields: [trashBinId], references: [id], onDelete: SetNull)
  locationId   String?      @db.Uuid
  location     Location?    @relation(fields: [locationId], references: [id], onDelete: SetNull)
  cameraId     String?      @db.Uuid
  camera       Camera?      @relation(fields: [cameraId], references: [id], onDelete: SetNull)
  // Recinto da tarefa (obrigatório). Resolvido na criação pela cadeia
  // trashBin/location/camera → coord (Turf) → Site default do tenant.
  siteId       String       @db.Uuid
  site         Site         @relation(fields: [siteId], references: [id], onDelete: Restrict)
  // Coordenadas próprias para tarefas posicionadas livremente no mapa (sem
  // vínculo a lixeira/posição/câmera). Preenchidas juntas ou ambas nulas.
  latitude     Float?
  longitude    Float?
  // Posicionamento dentro da planta de uma construção: tarefa avulsa colocada
  // num ponto do andar (locationId = construção). Espelha TrashBin/Camera.
  floor        String?  // andar onde a tarefa está, ex: "Térreo", "2", "-1"
  posX         Float?   // posição horizontal na planta do andar (0-100, %)
  posY         Float?   // posição vertical na planta do andar (0-100, %)
  assigneeRole UserRole
  assigneeName String?
  dueDate      DateTime?
  startedAt    DateTime?
  startedById  String?
  startedBy    User?        @relation("TaskStartedBy", fields: [startedById], references: [id], onDelete: SetNull)
  completedAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  notifications Notification[]

  @@index([tenantUuid])
  @@index([status])
  @@index([trashBinId])
  @@index([locationId])
  @@index([assigneeRole])
  @@index([cameraId])
  @@index([siteId])
  @@index([tenantUuid, trashBinId, kind, status])
  @@index([tenantUuid, completedAt])
  @@map("tasks")
}


model Notification {
  id         String           @id @default(uuid()) @db.Uuid
  tenantUuid String
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId     String?          @db.Uuid
  task       Task?            @relation(fields: [taskId], references: [id], onDelete: Cascade)
  kind       NotificationKind
  title      String
  body       String?
  readAt     DateTime?
  createdAt  DateTime         @default(now())

  @@index([tenantUuid, userId, readAt])
  @@index([userId, createdAt])
  @@map("notifications")
}
