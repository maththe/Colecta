generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TrashBinStatus {
  active
  inactive
  full
  maintenance
  offline
}

enum TaskStatus {
  pending
  in_progress
  done
  cancelled
}

enum TaskPriority {
  low
  medium
  high
  urgent
}

enum UserRole {
  ADMIN
  FUNCIONARIO
}

model User {
  id         String   @id @default(uuid())
  name       String
  email      String   @unique
  password   String
  tenantUuid String   @default(uuid())
  role       UserRole @default(FUNCIONARIO)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model TrashBin {
  id             String         @id @default(uuid()) @db.Uuid
  tenantUuid     String
  name           String
  code           String
  locationId     String         @db.Uuid
  location       Location       @relation(fields: [locationId], references: [id], onDelete: Restrict)
  capacityLiters Int
  status         TrashBinStatus @default(active)
  fillLevel      Int?
  batteryLevel   Int?
  lastSeenAt     DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  sensorReadings SensorReading[]
  tasks          Task[]

  @@unique([tenantUuid, code])
  @@index([tenantUuid])
  @@index([locationId])
  @@index([status])
  @@map("trash_bins")
}

model Location {
  id          String   @id @default(uuid()) @db.Uuid
  tenantUuid  String
  name        String
  description String?
  latitude    Float
  longitude   Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  trashBins TrashBin[]
  tasks     Task[]

  @@index([tenantUuid])
  @@index([tenantUuid, name])
  @@map("locations")
}

model SensorReading {
  id           String   @id @default(uuid()) @db.Uuid
  tenantUuid   String
  trashBinId   String   @db.Uuid
  trashBin     TrashBin @relation(fields: [trashBinId], references: [id], onDelete: Cascade)
  fillLevel    Int
  batteryLevel Int?
  temperature  Float?
  latitude     Float?
  longitude    Float?
  payload      Json?
  receivedAt   DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([tenantUuid, receivedAt])
  @@index([trashBinId, receivedAt])
  @@map("sensor_readings")
}

model Task {
  id           String       @id @default(uuid()) @db.Uuid
  tenantUuid   String
  title        String
  description  String?
  status       TaskStatus   @default(pending)
  priority     TaskPriority @default(medium)
  trashBinId   String?      @db.Uuid
  trashBin     TrashBin?    @relation(fields: [trashBinId], references: [id], onDelete: SetNull)
  locationId   String?      @db.Uuid
  location     Location?    @relation(fields: [locationId], references: [id], onDelete: SetNull)
  assigneeName String?
  dueDate      DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([tenantUuid])
  @@index([status])
  @@index([trashBinId])
  @@index([locationId])
  @@map("tasks")
}
