generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TrashBinStatus {
  active
  inactive
  full
  maintenance
  offline
}

enum CameraStatus {
  online
  offline
  maintenance
}

enum TaskStatus {
  pending
  in_progress
  done
  cancelled
}

enum TaskPriority {
  low
  medium
  high
  urgent
}

enum TaskKind {
  manual
  auto
}

enum UserRole {
  ADMIN
  MANUTENCAO
  LIMPEZA
  FINANCEIRO
  SEGURANCA
  /// Legado: mantido para bancos antigos que ainda tenham usuários genéricos.
  FUNCIONARIO
}

enum NotificationKind {
  task_assigned
  task_urgent
  task_overdue
  task_done
  task_auto
}

model User {
  id         String   @id @default(uuid())
  name       String
  email      String   @unique
  password   String
  tenantUuid String   @default(uuid())
  role       UserRole @default(LIMPEZA)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  startedTasks  Task[]         @relation("TaskStartedBy")
  notifications Notification[]

  @@map("users")
}

model TrashBin {
  id             String         @id @default(uuid()) @db.Uuid
  tenantUuid     String
  name           String
  code           String
  locationId     String         @db.Uuid
  location       Location       @relation(fields: [locationId], references: [id], onDelete: Restrict)
  capacityLiters Int
  status         TrashBinStatus @default(active)
  fillLevel      Int?
  batteryLevel   Int?
  mqttTopic      String?
  distanceEmptyCm Float?
  distanceFullCm  Float?
  lastSeenAt     DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  sensorReadings SensorReading[]
  tasks          Task[]
  cameras        Camera[]

  @@unique([tenantUuid, code])
  @@index([tenantUuid])
  @@index([tenantUuid, mqttTopic])
  @@index([locationId])
  @@index([status])
  @@map("trash_bins")
}

model Location {
  id          String   @id @default(uuid()) @db.Uuid
  tenantUuid  String
  name        String
  description String?
  latitude    Float
  longitude   Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  trashBins TrashBin[]
  tasks     Task[]
  cameras   Camera[]

  @@index([tenantUuid])
  @@index([tenantUuid, name])
  @@map("locations")
}

model Camera {
  id          String       @id @default(uuid()) @db.Uuid
  tenantUuid  String
  code        String
  name        String
  status      CameraStatus @default(online)
  model       String
  ipAddress   String
  resolution  String
  fps         Int
  latitude    Float
  longitude   Float
  imageUrl    String?
  notes       String?
  lastSeenAt  DateTime?
  locationId  String?      @db.Uuid
  location    Location?    @relation(fields: [locationId], references: [id], onDelete: SetNull)
  trashBinId  String?      @db.Uuid
  trashBin    TrashBin?    @relation(fields: [trashBinId], references: [id], onDelete: SetNull)
  tasks       Task[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([tenantUuid, code])
  @@index([tenantUuid])
  @@index([locationId])
  @@index([trashBinId])
  @@index([status])
  @@map("cameras")
}

model SensorReading {
  id           String   @id @default(uuid()) @db.Uuid
  tenantUuid   String
  trashBinId   String   @db.Uuid
  trashBin     TrashBin @relation(fields: [trashBinId], references: [id], onDelete: Cascade)
  fillLevel    Int?
  distanceCm   Float?
  batteryLevel Int?
  temperature  Float?
  latitude     Float?
  longitude    Float?
  sensorError  String?
  mqttTopic    String?
  deviceMillis Float?
  payload      Json?
  receivedAt   DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([tenantUuid, receivedAt])
  @@index([tenantUuid, mqttTopic, receivedAt])
  @@index([trashBinId, receivedAt])
  @@map("sensor_readings")
}

model Task {
  id           String       @id @default(uuid()) @db.Uuid
  tenantUuid   String
  title        String
  description  String?
  status       TaskStatus   @default(pending)
  priority     TaskPriority @default(medium)
  kind         TaskKind     @default(manual)
  issues       String[]     @default([])
  trashBinId   String?      @db.Uuid
  trashBin     TrashBin?    @relation(fields: [trashBinId], references: [id], onDelete: SetNull)
  locationId   String?      @db.Uuid
  location     Location?    @relation(fields: [locationId], references: [id], onDelete: SetNull)
  cameraId     String?      @db.Uuid
  camera       Camera?      @relation(fields: [cameraId], references: [id], onDelete: SetNull)
  assigneeRole UserRole
  assigneeName String?
  dueDate      DateTime?
  startedAt    DateTime?
  startedById  String?
  startedBy    User?        @relation("TaskStartedBy", fields: [startedById], references: [id], onDelete: SetNull)
  completedAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  notifications Notification[]

  @@index([tenantUuid])
  @@index([status])
  @@index([trashBinId])
  @@index([locationId])
  @@index([assigneeRole])
  @@index([cameraId])
  @@index([tenantUuid, trashBinId, kind, status])
  @@index([tenantUuid, completedAt])
  @@map("tasks")
}


model Notification {
  id         String           @id @default(uuid()) @db.Uuid
  tenantUuid String
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId     String?          @db.Uuid
  task       Task?            @relation(fields: [taskId], references: [id], onDelete: Cascade)
  kind       NotificationKind
  title      String
  body       String?
  readAt     DateTime?
  createdAt  DateTime         @default(now())

  @@index([tenantUuid, userId, readAt])
  @@index([userId, createdAt])
  @@map("notifications")
}
