{
  "name": "colecta",
  "version": "0.1.0",
  "private": true,
  "description": "Colecta - smart trash bin management MVP",
  "scripts": {
    "dev:web": "pnpm --filter @colecta/web dev",
    "dev:api": "pnpm --filter @colecta/api start:dev",
    "dev": "pnpm -r --parallel --stream run dev",
    "build": "pnpm -r run build",
    "db:migrate": "pnpm --filter @colecta/api prisma:migrate",
    "db:seed": "pnpm --filter @colecta/api prisma:seed",
    "db:generate": "pnpm --filter @colecta/api prisma:generate",
    "db:reset": "pnpm --filter @colecta/api prisma:reset"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild"
    ]
  }
}
